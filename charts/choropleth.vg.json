{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Hotel Occupancy Rates by Malaysian State",

 "width": 1000,
  "height": 420,

  "data": {
    "url": "https://lgam0005.github.io/FIT2179-DV2/data/malaysia_states.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },

  "transform": [
    {
      "lookup": "properties.name",
      "from": {
        "data": {
          "url": "../data/occupancy_rates.csv"
        },
        "key": "state",
        "fields": ["occupancy_2025", "occupancy_2024"]
      }
    },
    {
      "calculate": "datum.properties.name",
      "as": "state_name"
    }
  ],

  "projection": {
    "type": "mercator",
    "center": [109, 4],
    "scale": 2200

  },

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },

  "encoding": {
    "color": {
      "field": "occupancy_2025",
      "type": "quantitative",
      "title": "Occupancy Rate 2025 (%)",
      "scale": {
        "scheme": "blues"
      }
    },

    "tooltip": [
      {
        "field": "state_name",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "occupancy_2025",
        "type": "quantitative",
        "title": "2025 Occupancy (%)",
        "format": ".1f"
      },
      {
        "field": "occupancy_2024",
        "type": "quantitative",
        "title": "2024 Occupancy (%)",
        "format": ".1f"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}