{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Hotel Occupancy Rates by State (2024 vs 2025)",

  "data": {
    "url": "https://lgam0005.github.io/FIT2179-DV2/data/occupancy_rates.csv"
  },

  "transform": [
    {
      "fold": ["occupancy_2024", "occupancy_2025"],
      "as": ["Year", "Occupancy"]
    }
  ],

  "width": 950,
  "height": 420,

  "mark": "bar",

  "encoding": {

    "x": {
      "field": "state",
      "type": "nominal",
      "title": "State"
    },

    "xOffset": {
      "field": "Year"
    },

    "y": {
      "field": "Occupancy",
      "type": "quantitative",
      "title": "Occupancy Rate (%)"
    },

    "color": {
      "field": "Year",
      "type": "nominal"
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "Year",
        "type": "nominal"
      },
      {
        "field": "Occupancy",
        "type": "quantitative"
      }
    ]
  }
}