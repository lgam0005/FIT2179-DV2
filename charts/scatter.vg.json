{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Hotel Guest Growth by State",

  "data": {
    "url": "data/hotel_guests_states.csv"
  },

  "width": 600,
  "height": 350,

  "transform": [
    {
      "fold": ["guests 2024", "guests 2025"],
      "as": ["year", "guests"]
    }
  ],

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 120
    },
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "nominal",
      "title": "Year",
      "axis": {
        "labelAngle": 0
      }
    },

    "y": {
      "field": "guests",
      "type": "quantitative",
      "title": "Hotel Guests",
      "scale": {
        "zero": false
      }
    },

"color": {
  "field": "state",
  "type": "nominal",
  "title": "State",
  "scale": {
    "range": [
      "#0B7285",
      "#2A9D8F",
      "#5C7AEA",
      "#6BAED6",
      "#4C956C"
    ]
  }
},

    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "year",
        "type": "nominal",
        "title": "Year"
      },
      {
        "field": "guests",
        "type": "quantitative",
        "format": ",",
        "title": "Hotel Guests"
      }
    ]
  }
}