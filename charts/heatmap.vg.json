{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Hotel Occupancy Rate Heatmap",

  "data": {
    "url": "https://lgam0005.github.io/FIT2179-DV2/data/occupancy_rates.csv"
  },

  "transform": [
  {
    "fold": ["occupancy_2024", "occupancy_2025"],
    "as": ["Year", "Rate"]
  },
  {
    "calculate": "datum.Year == 'occupancy_2024' ? '2024' : '2025'",
    "as": "YearLabel"
  }
],

  "width": 850,
  "height": 320,

  "mark": "rect",

  "encoding": {

    "x": {
  "field": "YearLabel",
  "type": "nominal",
  "title": "Year"
},

    "y": {
      "field": "state",
      "type": "nominal",
      "title": "State"
    },

    "color": {
      "field": "Rate",
      "type": "quantitative",
      "title": "Occupancy Rate (%)"
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "Year",
        "type": "nominal"
      },
      {
        "field": "Rate",
        "type": "quantitative"
      }
    ]
  }
}