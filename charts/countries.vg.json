{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Top Source Countries for Visitors to Malaysia in 2024",

  "data": {
    "url": "https://lgam0005.github.io/FIT2179-DV2/data/source_countries.csv"
  },

  "width": 600,
  "height": 300,

  "mark": {
    "type": "bar"
  },

"encoding": {

  "y": {
    "field": "Country",
